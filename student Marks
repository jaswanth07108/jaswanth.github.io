import numpy as np
import pandas as pd
from matplotlib import pyplot as plt
import seaborn as sns

students=['sulochana','shannu','Jaswanth','shankar']
marks=[89,90,78,79]
data=pd.DataFrame({
    "Student":students,
    "Marks":marks
})
print(data)
print("\nAverage marks: ",np.mean(marks))
print("\nHighest Marks: ",np.max(marks))
print("\nLowest Marks: ",np.min(marks))

sns.barplot(x='Student',y='Marks',data=data)
plt.title("Marks Analysis")
plt.show()
